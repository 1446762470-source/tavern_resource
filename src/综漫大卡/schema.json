{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "default": {},
  "type": "object",
  "properties": {
    "主角": {
      "type": "object",
      "properties": {
        "姓名": {
          "default": "",
          "type": "string"
        },
        "性别": {
          "default": "男",
          "type": "string",
          "enum": [
            "男",
            "女"
          ]
        },
        "班级": {
          "default": "",
          "type": "string"
        },
        "自我介绍": {
          "default": "",
          "type": "string"
        },
        "余额": {
          "default": 50000,
          "type": "number"
        },
        "能力背包": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "能力id"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "名称": {
                "type": "string"
              },
              "稀有度": {
                "type": "string",
                "enum": [
                  "N",
                  "R",
                  "SR",
                  "SSR"
                ]
              },
              "分类": {
                "type": "string",
                "enum": [
                  "幸运",
                  "厄运",
                  "物品",
                  "事件",
                  "角色",
                  "无事"
                ]
              },
              "效果描述": {
                "default": "",
                "type": "string"
              },
              "获得时间": {
                "default": "",
                "type": "string"
              }
            },
            "required": [
              "名称",
              "稀有度",
              "分类"
            ]
          }
        },
        "抽卡统计": {
          "type": "object",
          "properties": {
            "总抽数": {
              "default": 0,
              "type": "number"
            },
            "N次数": {
              "default": 0,
              "type": "number"
            },
            "R次数": {
              "default": 0,
              "type": "number"
            },
            "SR次数": {
              "default": 0,
              "type": "number"
            },
            "SSR次数": {
              "default": 0,
              "type": "number"
            }
          }
        }
      },
      "required": [
        "抽卡统计"
      ]
    },
    "世界状态": {
      "type": "object",
      "properties": {
        "时间": {
          "type": "object",
          "properties": {
            "日期": {
              "default": "2012-04-09",
              "type": "string"
            },
            "当前片段": {
              "default": "早晨",
              "type": "string"
            }
          }
        },
        "季节": {
          "default": "春",
          "type": "string"
        },
        "天气": {
          "default": "晴天",
          "type": "string"
        }
      },
      "required": [
        "时间"
      ]
    },
    "角色列表": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "角色名"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "好感度": {
            "default": 0,
            "type": "number"
          }
        }
      }
    }
  },
  "required": [
    "主角",
    "世界状态"
  ]
}